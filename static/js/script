const sessions = {
    "Morning": {
        time: "09:00 - 10:30",
        capacity: 20,
        limits: {
            "Division A": 8,
            "Division B": 6,
            "Division C": 6
        },
        participants: []
    },
    "Midday": {
        time: "11:00 - 12:30",
        capacity: 20,
        limits: {
            "Division A": 8,
            "Division B": 6,
            "Division C": 6
        },
        participants: []
    },
    "Afternoon": {
        time: "13:00 - 14:30",
        capacity: 20,
        limits: {
            "Division A": 8,
            "Division B": 6,
            "Division C": 6
        },
        participants: []
    }
};

const form = document.getElementById("allocationForm");
const feedbackMessage = document.getElementById("feedbackMessage");
const sessionCards = document.getElementById("sessionCards");
const participantTable = document.getElementById("participantTable");

form.addEventListener("submit", function (event) {
    event.preventDefault();

    const participantName = document.getElementById("participantName").value.trim();
    const employeeId = document.getElementById("employeeId").value.trim();
    const department = document.getElementById("department").value;
    const selectedSession = document.getElementById("session").value;

    const validationResult = validateAllocation(
        participantName,
        employeeId,
        department,
        selectedSession
    );

    if (!validationResult.valid) {
        showFeedback(validationResult.message, "error");
        return;
    }

    sessions[selectedSession].participants.push({
        name: participantName,
        employeeId: employeeId,
        department: department,
        session: selectedSession
    });

    showFeedback(`${participantName} has been assigned to the ${selectedSession} session.`, "success");

    form.reset();
    renderSessions();
    renderParticipantTable();
});

function validateAllocation(name, employeeId, department, selectedSession) {
    if (!name || !employeeId || !department || !selectedSession) {
        return {
            valid: false,
            message: "Please complete all fields before assigning a participant."
        };
    }

    for (let sessionName in sessions) {
        const alreadyAssigned = sessions[sessionName].participants.some(
            participant => participant.employeeId.toLowerCase() === employeeId.toLowerCase()
        );

        if (alreadyAssigned) {
            return {
                valid: false,
                message: "Invalid allocation: this employee has already been assigned to a session."
            };
        }
    }

    const session = sessions[selectedSession];

    if (session.participants.length >= session.capacity) {
        return {
            valid: false,
            message: "Invalid allocation: this session is already full."
        };
    }

    const departmentCount = session.participants.filter(
        participant => participant.department === department
    ).length;

    if (departmentCount >= session.limits[department]) {
        return {
            valid: false,
            message: `Invalid allocation: ${department} has reached its limit for this session.`
        };
    }

    return {
        valid: true,
        message: "Allocation is valid."
    };
}

function renderSessions() {
    sessionCards.innerHTML = "";

    for (let sessionName in sessions) {
        const session = sessions[sessionName];
        const usedSeats = session.participants.length;
        const availableSeats = session.capacity - usedSeats;
        const percentageUsed = (usedSeats / session.capacity) * 100;

        let color = "#0d47a1"; // default blue

if (percentageUsed > 80) color = "#b71c1c"; // red if nearly full
else if (percentageUsed > 50) color = "#f9a825"; // yellow warning

        const divisionACount = countDepartment(session, "Division A");
        const divisionBCount = countDepartment(session, "Division B");
        const divisionCCount = countDepartment(session, "Division C");

        const card = document.createElement("div");
        card.className = "session-card";

        card.innerHTML = `
            <h3>${sessionName}</h3>
            <p><strong>Time Slot:</strong> ${session.time}</p>
            <p><strong>Used Seats:</strong> ${usedSeats}/20</p>
            <p><strong>Available Seats:</strong> ${availableSeats}</p>

            <div class="capacity-bar">
                <div class="capacity-fill" style="width: ${percentageUsed}%; background:${color}"></div>

            <p><strong>Division A:</strong> ${divisionACount}/8</p>
            <p><strong>Division B:</strong> ${divisionBCount}/6</p>
            <p><strong>Division C:</strong> ${divisionCCount}/6</p>
        `;

        sessionCards.appendChild(card);

        
    }
}

function renderParticipantTable() {
    participantTable.innerHTML = "";

    let allParticipants = [];

    for (let sessionName in sessions) {
        sessions[sessionName].participants.forEach(participant => {
            allParticipants.push({
                ...participant,
                time: sessions[sessionName].time
            });
        });
    }

    if (allParticipants.length === 0) {
        participantTable.innerHTML = `
            <tr>
                <td colspan="5">No participants have been allocated yet.</td>
            </tr>
        `;
        return;
    }

    allParticipants.forEach(participant => {
        const row = document.createElement("tr");

        row.innerHTML = `
            <td>${participant.employeeId}</td>
            <td>${participant.name}</td>
            <td>${participant.department}</td>
            <td>${participant.session}</td>
            <td>${participant.time}</td>
        `;

        participantTable.appendChild(row);
    });
}

function countDepartment(session, department) {
    return session.participants.filter(
        participant => participant.department === department
    ).length;
}

function showFeedback(message, type) {
    feedbackMessage.textContent = message;
    feedbackMessage.className = type;
}

renderSessions();
renderParticipantTable();